
!! # Skolt Saami noun morphology 

!! This file documents the Skolt Saami noun morphology, lexicon by lexicon.
!! cf. Mosnikoff et al 2020: 356
!! the notions of vowels in 9 rows AโI, and 5 columns
!! |(A)|a|รค|aสน|รคสน|รคสน|
!! |(B)|รต|รข|รตสน|รขสน|รขสน|
!! |(C)|u|o|uสน|oสน|uสน|
!! |(D)|o|รฅ|oสน|รฅสน|รฅสน|
!! |(E)|i|e|iสน|eสน|eสน|
!! |(F)|uรต|uรข|uรตสน|ueสน (<*uรขสน)| ueสน|
!! |(G)|uรฅ|uรค|ueสน (<*uรฅสน)|uรคสน/uแบนสน|uแบน /uรคสน|
!! |(H)|iรต|eรข|iรตสน|ieสน (<*eรขสน)|ieสน (<*eรขสน)|
!! |(I)|iรข|eรค|ieสน (<*iรขสน)|eรคสน/uแบนสน|eรคสน/uแบนสน|

!! F4,F5, G4, G5, H4, H5, I4, I5 are problematic, and for this reason they are not given as in the book,
!! diphthong + XX and YX -> uแบนสน, iแบนสน
!! diphthong + XหX and YXX -> uรคสน, eรคสน
!! column 1 is high; column 2 is low; column 3 is high with soft sign;
!! column 4 represents (vowel + XหX and YXX) context found in +V+Ind+Prs+Pl3 (cf. Mosnikoff et al 2020)
!! column 5 is low with monophthongs and analogically low with diphthongs (see Rueter, 2025 )

!! ## Unclassified words

LEXICON N_ !!= * @CODE@ FOR (STILL) UNCLASSIFIED INCOMING NOUNS.
+Sg+Nom: #; ! TODO: all cases

!testing with make  HFST_LEXC_FLAGS=--Werror
!NMN_PIGS;

LEXICON N_SG-NOM-ORPHAN
! For special +Sg+Nom when orphan from paradigm
+Sg+Nom: K ;

LEXICON N_SG-NOM-WITH-CMP
! For allowing compounding even though a word lacks full paradigm
+Sg+Nom: SG-NOM ;

!! IRREGULAR NOUN nijdd
LEXICON N_NIJDD !!= * @CODE@ nijdd:ni
!!! inflection_type="1"
: NMN_NIJDD ;

LEXICON	NMN_NIJDD	!!= * @CODE@ nijdd:ni
!! * Yaml: **N-nijdd**
!! NMN_1ร_IJCC
:jdd SG-NOM ;			!!= * @CODE@ nijdd
:jdd%>รข ESS/PAR ; 	  		!!= * @CODE@ nijddรขn, nijddรขd
!! strong_geminate, short_vowel, palatalization
:{สนร}jdd%^PAL%>e SG-ILL ;		!!= * @CODE@ niสนjdde
!! strong_geminate, long_vowel
:รตฤ SG-ABE/ACC/GEN_PL-NOM ;	!!= * @CODE@ niรตฤ
:รตฤ%>รข SG-LOC ;		!!= * @CODE@ niรตฤรขst
:รตฤ SG-COM_IN/PL-OBL ;	!!= * @CODE@ niรตฤ, niรตฤid, niรตฤid, niรตฤin, niรตฤivuiสนm, niรตฤitaa

+Der+Der/Dimin+N:รตฤ N_MUORYZH-WITHOUT-PAL ;  !!= * @CODE@ niรตฤ-
+Der+Der/Dimin+N:รต{สนร}ฤ%^PAL N_MUORYZH-WITH-PAL ;  !!= * @CODE@ niรตสนฤ-

:jdd HatY-STEM-PX-RETAIN ;
:รตฤ HatY-STEM-PX-WEAKEN ;
:รตฤ HatY-STEM-PX-WEAKEN_LARGO ;
:รตฤ SG-LOC-PX ;
:รตฤ HatY-STEM-PX-STRENGTHEN ;

+Err/GenreLeudd:รตฤรข SG-ABE/ACC/GEN_PL-NOM ;     !!= * @CODE@ niรตฤ Leudd 2018-09-20
+Err/GenreLeudd:รตฤรข SG-COM_N ; !!= * @CODE@ Leudd 2018-09-20


! Test data:
!!โฌgt-norm: nijdd #
!!โฌ nijdd:  	 nijdd+N+Sg+Nom
!!โฌ niรตฤ: 	 nijdd+N+Sg+Gen
!!โฌ niรตฤ: 	 nijdd+N+Sg+Acc
!!โฌ niสนjdde: 	 nijdd+N+Sg+Ill
!!โฌ niรตฤรขst: 	 nijdd+N+Sg+Loc
!!โฌ niรตฤstad: 	 nijdd+N+Sg+Loc+PxSg1
!!โฌ niรตฤin: 	 nijdd+N+Sg+Com
!!โฌ nijddรขn: 	 nijdd+N+Ess
!!โฌ nijddรขd: 	 nijdd+N+Par
!!โฌ niรตฤtaa: 	 nijdd+N+Sg+Abe
!!โฌ niรตฤ:	 nijdd+N+Pl+Nom
!!โฌ niรตฤi: 	 nijdd+N+Pl+Gen
!!โฌ niรตฤid: 	 nijdd+N+Pl+Acc
!!โฌ niรตฤid: 	 nijdd+N+Pl+Ill
!!โฌ niรตฤin: 	 nijdd+N+Pl+Loc
!!โฌ niรตฤivuiสนm:  nijdd+N+Pl+Com
!!โฌ niรตฤitaa: 	 nijdd+N+Pl+Abe
!!โฌ niรตฤรขลพ:      nijdd+N+Der+Der/Dimin+N+Sg+Nom
!!โฌ niรตสนฤe:      nijdd+N+Der+Der/Dimin+N+Sg+Gen



!! CLASS 1 HIGH VOWEL, NO PALATALIZATION NOMINALS
LEXICON N_1ร_VCC !!= * @CODE@ papp:pa%^1VOW{สนร}pp
!!! inflection_type="1"
!! similar_to: N_PESS
 NMN_1ร_VCC ;
LEXICON NMN_1ร_VCC
!! pa{a0}{สน0}{p0}p
!! V{V0}{สน0}{C0}C
!! Sg_Nom:
!! high-vowel=yes
!! monophthong=yes
!! long-vowel=yes
!! palatalization=no
!! consonantism=quant-gem
!! long-consonant=yes

!!! pos="nominal"
!!! syll_count-in-Sg_Nom="1"
!!! stem-ends-in="consonant"
!!! stem_vowel-in-Sg_Loc="รข"
!!! stem_with_gradation="yes" 
!! 1.1.1.1.1.1. Sg_Nom="short_vowel|geminate" Sg_Gen="long_vowel|geminate" 

! foot: 2syll
! diphthong: no
! vowel_shift: no
! consonant: geminate
! gradation: yes2
! weak_grade: no
! strong_grade:	geminate
! stem_vowel-in-Sg_Loc: รขst
! Sg.Ill: palatalization-AND-e
!! ## 1. WORDS WITH SINGLE-SYLLABLE NOMINATIVE SINGULARS (2009: 167)
!! ## 1.1 Sg.Loc in -รขst (no vowel shift, all raised)
!!  รข-stems (Sg.Loc, Ess, Par).
!! ## 1.1.1 Sg.Ill vowel	-e
!! ## 1.1.1.1 Has Palatalization
!! ## 1.1.1.1[1] (Palatalization pattern)
!!  Palatalized: Sg.Ill
!!  Not Palatalized: ELSE
!!    Sg.Ill in palatalization and -e
!! ## 1.1.1.1[1].1 Lacks Specifically Pedagogical Gradation
!! ## 1.1.1.1[1].1.1 Has Orthographic Gradation
!! ## 1.1.1.1[1].1.1[] (Monophthong + Consonant Geminate alternation)
!!  Extra strong grade: Sg.Nom, Ess, Par
!!  Extra strong grade: Sg.Ill
!!  Strong grade: Pl.Nom, Sg.Loc, Sg.Com
!! ## FORMS
!! * Yaml: **N-papp**
!! strong_geminate, short_vowel
: SG-NOM ;			!!= * @CODE@ papp
:%>รข ESS/PAR ; 	  		!!= * @CODE@ pappรขn, pappรขd
: A_DER/SAZH_Y ;

!! strong_geminate, short_vowel, palatalization
:%^PAL%>e SG-ILL ;		!!= * @CODE@ paสนppe
:%^PAL N2A_LUOQSSI ;		!!= * @CODE@ NยปA: paสนppi

!! strong_geminate, long_vowel
:%^V2VV SG-ABE/ACC/GEN_PL-NOM ;	!!= * @CODE@ paapp
:%^V2VV%>รข SG-LOC ;		!!= * @CODE@ paappรขst
:%^V2VV SG-COM_IN/PL-OBL ;	!!= * @CODE@ paappi, paappid, paappid, paappin, paappivuiสนm, paappitaa
:%^V2VV A_DER/LAZH ;

+Der+Der/Dimin+N:%^V2VV N_KUUZZYZH-WITHOUT-PAL ;  !!= * @CODE@ paapp-
+Der+Der/Dimin+N:%^V2VV%^PAL N_KUUZZYZH-WITH-PAL ;  !!= * @CODE@ paaสนpp-
+Der+Der/Dimin+N:%^PAL%^CC2CAllegro N_KUUZZYZH-WITH-PAL-ALLEGRO ;
!! papp+N+Der+Der/Dimin+N+Sg+Loc+PxSg3
!! paสนpstes

HatY-STEM-PX-RETAIN ;
:%^V2VV HatY-STEM-PX-WEAKEN ; !! e.g. 
:%^V2VV HatY-STEM-PX-WEAKEN_LARGO ; !! e.g. +Use/NG+Sg+Loc+PxSg3
:%^CC2CAllegro SG-LOC-PX_ALLEGRO ; !! e.g. +Sg+Loc+PxSg3 pp:p papstes
 HatY-STEM-PX-STRENGTHEN ;

LEXICON N_1ร_VCC_PL
+Cmp/SgNom: R ;          !!= * @CODE@ papp
:%^V2VV PL-NOM ; !!= * @CODE@ paapp
:%^V2VV PL-OBL ;      !!= * @CODE@ paappi, paappid, paappid, paappin, paappivuiสนm, paappitaa
:%>รข ESS/PAR ;                  !!= * @CODE@ pappรขn, pappรขd
: HatY-STEM-PX-RETAIN_PL ;
:%^V2VV HatY-STEM-PX-WEAKEN_PL ;
: HatY-STEM-PX-STRENGTHEN-ESS ;

! Test data:
!!โฌgt-norm: papp # 
!!โฌ papp:   	 papp+N+Sg+Nom
!!โฌ paapp: 	 papp+N+Sg+Gen
!!โฌ paapp: 	 papp+N+Sg+Acc
!!โฌ paสนppe: 	 papp+N+Sg+Ill
!!โฌ paappรขst: 	 papp+N+Sg+Loc
!!โฌ papstan: 	 papp+N+Sg+Loc+PxSg1
!!โฌ paappstan: 	 papp+N+Sg+Loc+PxSg1
!!โฌ paappin: 	 papp+N+Sg+Com
!!โฌ pappรขn: 	 papp+N+Ess
!!โฌ pappรขd: 	 papp+N+Par
!!โฌ paapptaa: 	 papp+N+Sg+Abe
!!โฌ paapp: 	 papp+N+Pl+Nom
!!โฌ paappi: 	 papp+N+Pl+Gen
!!โฌ paappid: 	 papp+N+Pl+Acc
!!โฌ paappid: 	 papp+N+Pl+Ill
!!โฌ paappin: 	 papp+N+Pl+Loc
!!โฌ paappivuiสนm: papp+N+Pl+Com
!!โฌ paappitaa: 	 papp+N+Pl+Abe
!!โฌ paappรขลพ: 	 papp+N+Der+Der/Dimin+N+Sg+Nom
!!โฌ paaสนppe: 	 papp+N+Der+Der/Dimin+N+Sg+Gen

LEXICON N_1ร_VKK
 NMN_1ร_VKK ;
LEXICON NMN_1ร_VKK
!! * Yaml: **N-pakk**
!! strong_geminate, short_vowel
: SG-NOM ;			!!= * @CODE@ papp
:%>รข ESS/PAR ; 	  		!!= * @CODE@ pappรขn, pappรขd
: A_DER/SAZH_Y ;

!! strong_geminate, short_vowel, palatalization
:%^PAL%^PALK%>e SG-ILL ;		!!= * @CODE@ paสนppe
:%^PAL%^PALK N2A_LUOQSSI ;		!!= * @CODE@ NยปA: paสนppi

!! strong_geminate, long_vowel
:%^V2VV SG-ABE/ACC/GEN_PL-NOM ;	!!= * @CODE@ paapp
:%^V2VV%>รข SG-LOC ;		!!= * @CODE@ paappรขst
:%^V2VV SG-COM_IN/PL-OBL ;	!!= * @CODE@ paappi, paappid, paappid, paappin, paappivuiสนm, paappitaa
:%^V2VV A_DER/LAZH ;

+Der+Der/Dimin+N:%^V2VV N_KUUZZYZH-WITHOUT-PAL ;  !!= * @CODE@ paapp-
+Der+Der/Dimin+N:%^V2VV%^PAL%^PALK N_KUUZZYZH-WITH-PAL ;  !!= * @CODE@ paaสนpp-
+Der+Der/Dimin+N:%^PAL%^CC2CAllegro%^PALK N_KUUZZYZH-WITH-PAL-ALLEGRO ;
!! papp+N+Der+Der/Dimin+N+Sg+Loc+PxSg3
!! paสนpstes

HatY-STEM-PX-RETAIN ;
:%^V2VV HatY-STEM-PX-WEAKEN ; !! e.g. 
:%^V2VV HatY-STEM-PX-WEAKEN_LARGO ; !! e.g. +Use/NG+Sg+Loc+PxSg3
:%^CC2CAllegro SG-LOC-PX_ALLEGRO ; !! e.g. +Sg+Loc+PxSg3 pp:p papstes
 HatY-STEM-PX-STRENGTHEN ;

LEXICON N_1ร_VYKK_errorth !!= * @CODE@
+Err/Orth: N_1ร_VYKK ;
LEXICON N_1ร_VYKK !!= * @CODE@ algg:a%^1VOW{สนร}lgg
 NMN_1ร_VYKK ;
LEXICON NMN_1ร_VYKK
!! * Yaml: **N-algg**
!! 
: SG-NOM ;	    				!!= * @CODE@ pรตrtt
: A_DER/SAZH_Y ;

:%^V2VV%^YXX2YX SG-ABE/ACC/GEN ;		!!= * @CODE@ pรตรตrt
:%^V2VV%^YXX2YX PL-NOM ;		!!= * @CODE@ pรตรตrt
:%^V2VV%^YXX2YX A_DER/LAZH ;
:%^PAL%^PALK%>e SG-ILL ;		      		!!= * @CODE@ pรตสนrtte
:%^PAL%^PALK N2A_LUOQSSI ;		      	!!= * @CODE@ pรตสนrtti
:%^V2VV%^YXX2YX%>รข SG-LOC ;			!!= * @CODE@ pรตรตrtรขst
:%^V2VV%^YXX2YX SG-COM_IN ;			!!= * @CODE@ pรตรตrtin
:%>รข ESS/PAR ; 		  			!!= * @CODE@ pรตrttรขn
:%^V2VV%^YXX2YX PL-OBL ;			!!= * @CODE@ pรตรตrti

+Der+Der/Dimin+N:%^V2VV%^YXX2YX N_KUUZZYZH-WITHOUT-PAL ;  !!= * @CODE@ pรตรตrt-
+Der+Der/Dimin+N:%^V2VV%^PAL%^YXX2YX%^PALK N_KUUZZYZH-WITH-PAL ;  !!= * @CODE@ pรตรตสนrt-
+Der+Der/Dimin+N:%^PAL%^YXX2YX%^PALK N_KUUZZYZH-WITH-PAL-ALLEGRO ;

HatY-STEM-PX-RETAIN ;
:%^V2VV%^YXX2YX HatY-STEM-PX-WEAKEN ;
:%^V2VV%^YXX2YX HatY-STEM-PX-WEAKEN_LARGO ;
:%^YXX2YX SG-LOC-PX_ALLEGRO ;
: HatY-STEM-PX-STRENGTHEN ;


LEXICON N_1ร_VYXX !!= * @CODE@ pรตrtt:pรต%^1VOW{สนร}rtt
!!! inflection_type="1"
 NMN_1ร_VYXX ;
LEXICON NMN_1ร_VYXX
!! Sg_Nom: vow_mono:vow_short:vow_high:pal_no:cns_xyy
!! similar_to: N_TAALKYS, N_KOONTYR
!!! pos="nominal"
!!! syll_count-in-Sg_Nom="1"
!!! stem-ends-in="consonant"
!!! stem_vowel-in-Sg_Loc="รข"
!!! stem_with_gradation="yes" 
!! 1.1.1.1.1.1. Sg_Nom="short_vowel|long_cluster" Sg_Gen="long_vowel|short_cluster" 

! foot: 2syll
! diphthong: no
! vowel_shift: no
! consonant: cluster
! gradation: yes2
! weak_grade: short
! strong_grade: long
! stem_vowel-in-Sg_Loc: รขst
! Sg.Ill: palatalization-AND-e
!! ## 1. WORDS WITH SINGLE-SYLLABLE NOMINATIVE SINGULARS (2009: 167)
!! ## 1.1 Sg.Loc in -รขst (no vowel shift, all raised)
!!  รข-stems (Sg.Loc, Ess, Par).
!! ## 1.1.1 Sg.Ill vowel	-e
!! ## 1.1.1.1 Has Palatalization
!! ## 1.1.1.1[1] (Palatalization pattern)
!!  Palatalized: Sg.Ill
!!  Not Palatalized: ELSE
!!    Sg.Ill in palatalization and -e
!! ## 1.1.1.1[1].1 Lacks Specifically Pedagogical Gradation
!! ## 1.1.1.1[1].1.1 Has Orthographic Gradation
!! ## 1.1.1.1[1].1.1[] (Monophthong + Consonant Cluster alternation)
!!  Strong grade: Sg.Nom, Ess, Par
!!  Strong grade: Sg.Ill
!!  Weak grade: Pl.Nom, Sg.Loc, Sg.Com
!! ## FORMS
!! * Yaml: **N-algg**
!! 
: SG-NOM ;	    				!!= * @CODE@ pรตrtt
: A_DER/SAZH_Y ;

:%^V2VV%^YXX2YX SG-ABE/ACC/GEN ;		!!= * @CODE@ pรตรตrt
:%^V2VV%^YXX2YX PL-NOM ;		!!= * @CODE@ pรตรตrt
:%^V2VV%^YXX2YX A_DER/LAZH ;
:%^PAL%>e SG-ILL ;		      		!!= * @CODE@ pรตสนrtte
:%^PAL N2A_LUOQSSI ;		      	!!= * @CODE@ pรตสนrtti
:%^V2VV%^YXX2YX%>รข SG-LOC ;			!!= * @CODE@ pรตรตrtรขst
:%^V2VV%^YXX2YX SG-COM_IN ;			!!= * @CODE@ pรตรตrtin
:%>รข ESS/PAR ; 		  			!!= * @CODE@ pรตrttรขn
:%^V2VV%^YXX2YX PL-OBL ;			!!= * @CODE@ pรตรตrti

+Der+Der/Dimin+N:%^V2VV%^YXX2YX N_KUUZZYZH-WITHOUT-PAL ;  !!= * @CODE@ pรตรตrt-
+Der+Der/Dimin+N:%^V2VV%^PAL%^YXX2YX N_KUUZZYZH-WITH-PAL ;  !!= * @CODE@ pรตรตสนrt-
+Der+Der/Dimin+N:%^PAL%^YXX2YX N_KUUZZYZH-WITH-PAL-ALLEGRO ; !!= * @CODE@ pรตสนrt-

HatY-STEM-PX-RETAIN ;
:%^V2VV%^YXX2YX HatY-STEM-PX-WEAKEN ;
:%^V2VV%^YXX2YX HatY-STEM-PX-WEAKEN_LARGO ;
:%^YXX2YX SG-LOC-PX_ALLEGRO ;
: HatY-STEM-PX-STRENGTHEN ;

LEXICON N_1ร_VYKK_PL !!= * @CODE@ aalวฅ:algg
+Cmp/SgNom: R ;                           !!= * @CODE@ pรตrtt
:%^V2VV%^YXX2YX PL-NOM ;                !!= * @CODE@ pรตรตrt
:%>รข ESS/PAR ;                                  !!= * @CODE@ pรตrttรขn
:%^V2VV%^YXX2YX PL-OBL ;                        !!= * @CODE@ pรตรตrti

LEXICON N_1ร_VYXX_PL !!= * @CODE@ pรตรตrt:pรตrtt
