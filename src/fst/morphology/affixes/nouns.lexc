LEXICON N_MAADD !!= * @CODE@ maadd:madd
!!! inflection_type="3"
: NMN_MAADD ;
LEXICON NMN_MAADD !!= * @CODE@ maadd:madd
! gradation: yes
! vowel_center: monophthong
! consonant_center: geminate
! sg_nom_grade: weak
!     VV2V
!! is for nouns with stem *i* + *-est* +Sg+Loc; all stem other than the +Sg+Nom are X3; the *i* does not occur in +Par 
!! * Yaml: **N-maadd**
!! * There are several stem types 
!! * maadd:maadd
!! strong_geminate, long_vowel, no-palatalization, high_stem_vowel
:%^V2VV SG-NOM ;
:%^V2VV%>รข ESS/PAR ; ! maaddรขn, maaddรขd, ref. Miika Lehtinen
!! strong_geminate, short_vowel, no-palatalization, high_stem_vowel
:%>i SG-ACC/GEN ;	 ! maddi
+Use/NGminip+Use/NG:%>วฅ%>a SG-ABE_tta ;
:%>i SG-ABE ;	 ! maddi
:%>วฅ%>a SG-ILL ;
+Use/NGminip+Use/NG:%>{สผร}j%>a SG-ILL ;
:%>{สผร}j%>e SG-LOC ;
:%>{สผร}j SG-COM_IN/PL-OBL ;
:%>i PL-NOM ;	 ! maddi
:%>{สผร}j%>e ESS/PAR ; ! maddjen, maddjest
+Use/NGminip+Use/NG:%>e PAR ;

+Der+Der/Dimin+N:%>{สผร}j N_KUYLAZH ;
+Der+Der/Dimin+N:%>วฅ N_KUYLAZH ;
:%^V2VV A_DER/SAZH ;
:%>วฅ VOONYS-STEM-PX ; !!= * @CODE@ vรตnns-
:%>{สผร}j VOONYS-STEM-PX ; !!= * @CODE@ vรตnns-

