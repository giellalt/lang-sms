!! ## 1. WORDS WITH SINGLE-SYLLABLE NOMINATIVE SINGULARS (2009: 167)
!! ## 1.1 Sg.Loc in -รขst. รข-stems (Sg.Loc, Ess, Par).
!! ## 1.1.3 Sg.Ill in palatalization and -e
!! ## 1.1.3.2 LACKS Gradation
!! ## 1.1.3.2.1 Monophthong
!! ## 1.1.3.2.1.1 Consonant Geminate
!! ## 1.1.3.2.1.1.2 Sg.Nom Strong Grade
!! ## 1.1.3.2.1.1.2.2.Sg.Gen Strong Grade
!! ## 1.1.3.2.1.1.2.2.2 Sg.Ill Strong Grade
!! luukk:luukk is for nouns with -รขst Loc and no gradation. N_Y-EPal1-11, N_Y-EPal2-22
!! * Yaml: **saarf, luukk**
 SG-NOM ;
: A_DER/SAZH ;
 SG-ABE/ACC/GEN_PL-NOM ;
: A_DER/LAZH ;
 NMN_SG-ILL_PAL_E ;
 NMN_SG-LOC_Y ;
 SG-COM_IN ;
 NMN_ESS_Y ; ! ess and prt without
 NMN_PAR_Y ;
 PL-OBL ;
+Der+Der/Dimin+N: N_KUUZZYZH-WITHOUT-PAL ;  !!= * @CODE@ paar-
+Der+Der/Dimin+N:%^PAL N_KUUZZYZH-WITH-PAL ;  !!= * @CODE@ paaสนr-


LEXICON N_BIOLOOG !!= * @CODE@ bioloog:bioloog
!!! inflection_type="?"
: NMN_BIOLOOG ;
LEXICON NMN_BIOLOOG
! gradation: no
!! ## 2. WORDS WITH TWO-SYLLABLE NOMINATIVE SINGULARS (2009: 288)
!! ## 2.1 Sg.Loc in -รขst. รข-stems (Sg.Loc, Ess, Par).
!! ## 2.1.3 Sg.Ill in palatalization and -e
!! ## 2.1.3.3 Lacks Gradation (in last syllable)
!! ## 2.1.3.3.1 Monophthong
!! ## 2.1.3.3.1.3 Consonant always short
!! ## 2.1.3.3.1.3.4 Sg.Nom long vowel AND Short consonant
!! ## 2.1.3.3.1.3.4.1.Sg.Gen Weak Grade
!! ## 2.1.3.3.1.3.4.1.3 Sg.Ill Weak Grade
!! bioloog:bioloog
!! * Yaml: **N-bioloog**
: SG-NOM ;		! bioloog
: SG-ABE/ACC/GEN_PL-NOM ;		! bioloog
:%^VV2V%^PAL%>e SG-ILL ;	! bioloสนวงe
:%>รข SG-LOC ;	 	! bioloogรขst
: SG-COM_IN ;		! bioloogin
:%>รข ESS/PAR ;  		! bioloogรขn
: PL-OBL ;		! bioloogi
+Der+Der/Dimin+N: N_MUORYZH-WITHOUT-PAL ;  !!= * @CODE@ bioloog-
+Der+Der/Dimin+N:%^PAL N_MUORYZH-WITH-PAL ;  !!= * @CODE@ biolooสนวง-

