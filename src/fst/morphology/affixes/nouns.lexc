LEXICON N_MUU3 !!= * @CODE@ muuส:muvสส
!!! inflection_type="3"
: NMN_MUU3 ;
LEXICON NMN_MUU3 !!= * @CODE@ muuส:muvสส
! gradation: yes
!! ## 1. WORDS WITH SINGLE-SYLLABLE NOMINATIVE SINGULARS (2009: 180)
!! ## 1.3 Sg.Loc in -est (no vowel shift, all raised)
!!  e-stems (Sg.Loc, Ess, Par).
!! ## 1.3.2 Sg.Ill vowel -a
!! ## 1.3.2.2 Lacks Palatalization
!! ## 1.3.2.2.1 Lacks Specifically Pedagogical Gradation
!! ## 1.3.2.2.1.1 Has Orthographic Gradation
!! ## 1.3.2.2.1.1[] (Monophthong + Consonant Cluster Variation)
!!  Weak grade: Sg.Nom
!!  Extra strong grade: Ess, Par
!!  Extra strong grade: Sg.Ill
!!  Extra strong grade: Pl.Nom, Sg.Loc, Sg.Com
!! ## FORMS
!! ## (1) Sg.Nom: muuส
!! ## (2) Pl.Nom: muvสสi
!! ## (3) Sg.Ill: muvสสวฅa
!! ## (4) Sg.Loc: muvสสjest
!! ## (5) Sg.Com: muvสสin
!! ## (6) Ess: muvสสen
!! ## (7) Par: muvสสed
!! ## (8) Pl.Acc: muvสสjid
!! ## (9) Der/Dimin.N.Sg.Nom:
!! * Yaml: **N-muuz**
!! * There are several stem types 
!! * muuส:muvสสi
:%^YXX2VX SG-NOM ;	       		!!(1) Sg.Nom: muuส
:%>i SG-ACC/GEN ;		!!(2) Pl.Nom: muvสสi
+Use/NGminip+Use/NG:%>วฅ%>a SG-ABE_tta ;
:%>i SG-ABE ;		! muvสสi
:%>วฅa SG-ILL ;	   !!(3) Sg.Ill: muvสสวฅa
:%>je SG-LOC ;	   !!(4) Sg.Loc: muvสสjest, checked with Markus Juutinen, 2025-09-25 TTy
+Use/NGminip+Use/NG:%>e SG-LOC ;	   !!(4) Sg.Loc: muvสสest, might really be an Err/Orth, 2025-09-25 TTy
: SG-COM_IN ;	   !!(5) Sg.Com: muvสสin
:%>e ESS/PAR ;  	   !!(6) Ess: muvสสen
:%>i PL-NOM ;		! muvสสi
:%>{สผร}ji PL-OBL ;		!(8) Pl.Gen: muvสสji
:%^YXX2VX A_DER/SAZH ;
:%>วฅ VOONYS-STEM-PX ; !!= * @CODE@ vรตnns-


!! CLASS 2 NOMINALS with low stem vowel and u-stems
!! ## u-stems
LEXICON N_MAEAEN !!= * @CODE@ mรครคn:ma%^1VOWnn
!!! inflection_type="3"
: NMN_MAEAEN ;
LEXICON NMN_MAEAEN !!= * @CODE@ mรครคn:ma%^1VOWnn
! gradation: yes
!! ## 1. WORDS WITH SINGLE-SYLLABLE NOMINATIVE SINGULARS (2009: 228)
!! ## 1.2 Sg.Loc in -ust. u-stems (Sg.Loc, Ess, Par).
!! ## 1.2.3 Sg.Ill in raised vowel and -u
!! ## 1.2.3.1 Has Gradation
!! ## 1.2.3.1.1 Monophthong
!! ## 1.2.3.1.1.1 Consonant Geminate (W2XSt)
!! ## 1.2.3.1.1.1.1 Sg.Nom Weak Grade
!! ## 1.2.3.1.1.1.1.3.Sg.Gen Extra Strong Grade
!! ## 1.2.3.1.1.1.1.3.3 Sg.Ill Extra Strong Grade
!! ## 1.2.3.1.1.1.1.3.3.Q All but Sg.Nom are raised vowels
!NumContLex="1.1299999999999999"
!! * Yaml: **N-maan**
!! * There are several stem types
:%^V2VV%^VOWLower%^CC2C SG-NOM ;	        !!= * @CODE@ mรครคn
:%>u SG-ABE/ACC/GEN_PL-NOM ;	 		 !!= * @CODE@ mannu
:%^VOWLower%>สผja SG-ILL ;
+Use/NGminip+Use/NG:%^VOWLower%>วฅa SG-ILL ;
:%>u SG-LOC ;
:%^VOWLower%>สผje SG-LOC ;
:%>u SG-COM_IN/PL-OBL ;
:%^VOWLower%>สผj SG-COM_IN ;
:%^VOWLower%>สผje ESS/PAR ; ! ess and prt without
+Use/NGminip+Use/NG:%^VOWLower%>u PAR ;
:%^VOWLower%>สผj VOONYS-STEM-PX ;

